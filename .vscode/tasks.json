{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vitest: Run all tests",
      "type": "shell",
      "command": "npm run test:run",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Vitest: Watch",
      "type": "shell",
      "command": "npm test",
      "group": "test",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "GraphQL: Run codegen",
      "type": "shell",
      "command": "npm run codegen",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Playwright: a11y tests",
      "type": "shell",
      "command": "npm run test:a11y",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Storybook: Dev server",
      "type": "shell",
      "command": "npm run storybook",
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Storybook",
          "endsPattern": "Storybook \\d+\\.\\d+\\.\\d+ for"
        }
      }
    },
    {
      "label": "Storybook: Build",
      "type": "shell",
      "command": "npm run build-storybook",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "ESLint: Lint",
      "type": "shell",
      "command": "npm run lint",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"]
    }
  ]
}
